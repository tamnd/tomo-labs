# Local override: inject a tomo binary built from the working tree instead of go
# install @ref, so the default-engine column reflects the same source as the
# tomo-cx and tomo-oi local images. adapter.sh is shared with the published image.
FROM tomolab-base
COPY tomo-local /usr/local/bin/tomo
COPY adapter.sh /usr/local/bin/adapter
RUN chmod +x /usr/local/bin/tomo /usr/local/bin/adapter
ENTRYPOINT ["/usr/local/bin/adapter"]
