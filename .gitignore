# Run artifacts, bare git mirrors, and grader venvs all live under the data root
# ($LAB_DATA, default $HOME/data/tomo-labs), outside the repo, so nothing heavy
# belongs in the checkout. These are just the stray local build and editor droppings.
proxy/proxy
*.log
.DS_Store
bin/
__pycache__/

# Legacy in-repo locations: older runs put the grader venv and the bare git
# mirrors beside the tasks. They live under the data root now, but keep ignoring
# these so an old working copy never stages a multi-gigabyte cache.
evals/*/.venv/
evals/*/.cache/

# The cmd/lab binary, built for local runs.
/lab

# Local docs build output. CI builds the site into its own output dirs.
docs/public/
docs/public-pages/
docs/public-cf/
docs/content-lastmods.json
