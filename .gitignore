# Run artifacts live under $HOME/data, outside the repo, so nothing to ignore
# there. These are just the stray local build and editor droppings.
proxy/proxy
*.log
.DS_Store
bin/

# The evalplus grader builds a numpy venv beside the tasks the first time it runs.
# It is a local cache, rebuilt on demand, so it never belongs in the repo.
evals/*/.venv/
__pycache__/
